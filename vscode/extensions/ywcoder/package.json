{
  "name": "ywcoder",
  "displayName": "YwCoder",
  "description": "YwCoder - 自研智能编程助手，深度集成于 VSCode，提供智能代码分析、重构建议、自动化编程等功能。",
  "version": "1.0.0",
  "publisher": "dc-ops-support",
  "engines": {
    "vscode": "^1.98.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Programming Languages"
  ],
  "icon": "resources/ywcoder-logo.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "configuration": {
      "title": "YwCoder 配置",
      "properties": {
        "ywcoder.selectedModel": {
          "type": "string",
          "default": "default",
          "description": "选择 AI 模型"
        },
        "ywcoder.environmentVariables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "环境变量名称"
              },
              "value": {
                "type": "string",
                "description": "环境变量值"
              }
            },
            "required": [
              "name",
              "value"
            ]
          },
          "default": [],
          "description": "启动时设置的环境变量"
        }
      }
    },
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "ywcoder-chat-sidebar",
          "title": "YwCoder",
          "icon": "resources/ywcoder-icon.svg"
        }
      ]
    },
    "views": {
      "ywcoder-chat-sidebar": [
        {
          "icon": "resources/ywcoder-icon.svg",
          "type": "webview",
          "id": "ywcoder.chatView",
          "name": "YwCoder"
        }
      ]
    },
    "commands": [
      {
        "command": "ywcoder.showChat",
        "title": "显示 YwCoder"
      },
      {
        "command": "ywcoder.openSettings",
        "title": "YwCoder: 打开设置",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ywcoder.openSettings",
          "when": "view == ywcoder.chatView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:webview\" \"npm run watch:extension\"",
    "dev:webview": "vite --config src/webview/vite.config.ts --port 5173 --strictPort",
    "build:extension": "tsx esbuild.ts --production",
    "build:webview": "vite build --config src/webview/vite.config.ts",
    "build": "npm run build:webview && npm run build:extension",
    "watch:extension": "tsx esbuild.ts --watch",
    "watch:webview": "vite build --config src/webview/vite.config.ts --watch",
    "watch": "concurrently \"npm run watch:extension\" \"npm run watch:webview\"",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:webview": "vue-tsc -p src/webview/tsconfig.json --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:webview",
    "prepackage": "npm run build",
    "package": "vsce package --no-dependencies",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue}\" && eslint src --ext ts,tsx,vue --fix"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.98.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vscode/vsce": "^3.7.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.1",
    "vue-vine": "^1.7.27"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.76",
    "@anthropic-ai/sdk": "^0.71.2",
    "@gn8/alien-signals-vue": "^0.1.1",
    "@mdi/font": "^7.4.47",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@vscode/codicons": "^0.0.44",
    "@vueuse/core": "^14.1.0",
    "alien-signals": "^3.1.2",
    "fuse.js": "^7.1.0",
    "lexical": "^0.39.0",
    "lexical-vue": "^0.14.1",
    "marked": "^17.0.1",
    "motion-v": "^1.7.4",
    "path-browserify-esm": "^1.0.6",
    "pinia": "^3.0.4",
    "reka-ui": "^2.8.0",
    "vue": "^3.5.26",
    "zod": "^3.25.76"
  },
  "keywords": [
    "vscode",
    "extension",
    "ai",
    "coding-assistant",
    "programming",
    "code-analysis",
    "智能编程",
    "代码助手"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourcompany/ywcoder"
  },
  "license": "AGPL-3.0"
}
